# =============================================================================
# Pulse env vars — see packages/shared/src/env.ts for the authoritative schema
# =============================================================================

# --- Pulse env identity ---
NODE_ENV=development
PULSE_ENV=local                       # local | staging | prod
NEXT_PUBLIC_PULSE_ENV=local

# --- Database (Postgres) ---
DATABASE_URL=postgres://pulse:pulse@localhost:5432/pulse

# --- Web app ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Clerk (stub locally; real values required in staging/prod) ---
CLERK_PUBLISHABLE_KEY=pk_test_stub
CLERK_SECRET_KEY=sk_test_stub
CLERK_WEBHOOK_SECRET=whsec_stub
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_stub

# --- Inngest ---
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Sentry ---
SENTRY_DSN_API=
NEXT_PUBLIC_SENTRY_DSN_WEB=
SENTRY_AUTH_TOKEN=

# --- Axiom ---
AXIOM_TOKEN=
AXIOM_DATASET=pulse-logs

# --- PostHog ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
POSTHOG_API_KEY=
